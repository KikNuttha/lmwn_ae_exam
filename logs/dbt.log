  create view "ae_exam_db"."main"."model_int_driver_incentive__dbt_tmp" as (
    with order as (
        select * from "ae_exam_db"."main"."model_sg_trn_order"
    ),

    drivers as (
        select * from "ae_exam_db"."main"."model_sg_mst_drivers"
    ),

    driver_incentive as (
        select * from "ae_exam_db"."main"."model_sg_log_driver_incentive"
    ),

    daily_driver_performance as (
        -- Aggregate daily performance metrics from order transactions
        select
            driver_id,
            cast(order_datetime as date) as activity_date,
            count(order_id) as orders_completed,
            -- Calculate average delivery time (pickup to delivery) in minutes
            avg(date_diff('minute', cast(pickup_datetime as timestamp), cast(delivery_datetime as timestamp))) as avg_delivery_duration_min
        from order
        where order_status = 'completed'
        group by 1, 2
    )

select
    i.log_id,
    i.driver_id,
    d.vehicle_type,
    i.region,
    i.incentive_program, -- Participation in specific programs (weekly, rainy day, etc.)
    i.applied_date,
    i.bonus_amount,
    i.bonus_qualified, -- Qualification status based on targets
    p.orders_completed as actual_deliveries_on_date,
    p.avg_delivery_duration_min
from driver_incentive i
inner join drivers d 
    on i.driver_id = d.driver_id
left join daily_driver_performance p 
    on i.driver_id = p.driver_id 
    and i.applied_date = p.activity_date
  );

