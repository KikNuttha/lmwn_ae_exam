[0m19:32:21.209206 [debug] [Thread-1 (]: On model.lmwn_ae_exam.int_marketing_attribution: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "lmwn_ae_exam", "target_name": "dev", "node_id": "model.lmwn_ae_exam.int_marketing_attribution"} */

  
  create view "ae_exam_db"."main"."int_marketing_attribution__dbt_tmp" as (
    -- For Campaign Effectiveness Report --
with campaign as (
    select * from "ae_exam_db"."main"."sg_mst_campaign"
),

interactions as (
    select * from "ae_exam_db"."main"."sg_log_camp_interac"
),

attribution as (
    select
        c.campaign_id,
        c.campaign_name,
        c.campaign_type,
        c.objective,
        c.channel,
        c.budget,
        c.targeting_strategy,
        i.customer_id,
        cast(i.interaction_dt as date) as interaction_date,
        i.event_type,
        i.platform,
        i.ad_cost,
        i.is_new_customer,
        i.revenue
    from campaign c
    left join interactions i    
        on c.campaign_id = i.campaign_id 
    where cast(i.interaction_dt as date) between c.start_dt and c.end_dt
)

select *
from attribution
  );

