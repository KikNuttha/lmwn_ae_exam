    case 
        when current_status != 'resolved' then 1 
        else 0 
    end as is_unresolved,
    case 
        when current_status = 'resolved' then 1 
        else 0 
    end as is_resolved,
    compensation_amount,
    cast(opened_datetime as date) as opened_date,
    month(opened_datetime) as opened_date_mm,
    year(opened_datetime) as opened_date_yyyy
from raw_tickets
  );

